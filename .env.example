# ============================================================
# juhuo 环境变量配置
# ============================================================
#
# 使用方式（二选一）：
#
#   方式 A（推荐）：用户级配置，从不提交到 git
#     → 创建 ~/.juhuo/.env（Linux/macOS/Windows 均适用）
#     → 将下面的内容复制进去，填入你的真实 API key
#     → 示例（Windows）：C:\Users\你的用户名\.juhuo\.env
#
#   方式 B（项目级）：把此文件复制到项目根目录，命名为 .env
#     → cp .env.example .env
#     → 填入 API key
#     → ⚠️ 注意：不要把真实的 .env 提交到 git！
#
# ============================================================

# MiniMax API Key（必需）
# 获取地址：https://www.minimaxi.com/user-center/basic-information/interface-key
# MINIMAX_API_KEY=your_key_here

# LLM 模型（可选，默认 MiniMax-M2.7）
# LLM_MODEL=MiniMax-M2.7

# 最大 Token 数（可选，默认 4096）
# MAX_TOKEN=4096

# Temperature（可选，默认 0.7）
# TEMPERATURE=0.7
