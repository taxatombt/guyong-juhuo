# Juhuo 配置示例
# 复制为 .env 并填入实际值

# LLM API 配置
OPENAI_API_KEY=sk-your-key-here
MINIMAX_API_KEY=your-minimax-key
ANTHROPIC_API_KEY=sk-ant-your-key

# Self-Evolver 参数（测试用）
# 生产使用代码中的默认值，不需要在此配置
# BIAS_CONSECUTIVE=3    # 连续3次错误触发
# MIN_SAMPLES=5         # 至少5个样本
# COOLDOWN_HOURS=24     # 冷却24小时
# VALIDATION_WINDOW=10  # 验证窗口

# 数据库（可选，使用默认路径）
# DATA_DIR=~/.juhuo/data

# Web 端口（可选，默认18765）
# WEB_PORT=18765
